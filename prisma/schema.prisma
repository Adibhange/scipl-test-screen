generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Candidate {
  id         String   @id @default(cuid())
  name       String
  mobile     String
  email      String
  role       String
  experience String
  createdAt  DateTime @default(now())
}

model Question {
  id         String   @id @default(cuid())
  title      String
  content    String
  role       String
  experience String
  difficulty String
  createdAt  DateTime @default(now())
}